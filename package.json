{
  "name": "beamho-bench",
  "version": "1.0.0",
  "description": "Interactive 3D Spatial Visualization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test:sim": "node scripts/run-sim-tests.mjs",
    "sync:tle-fixtures": "node scripts/sync-tle-fixtures.mjs",
    "enrich:tle-fixtures": "node scripts/enrich-tle-fixtures.mjs",
    "validate:rigor": "node scripts/validate-academic-rigor.mjs",
    "bench:cross-mode": "node scripts/run-cross-mode-benchmark.mjs",
    "bundle:repro-v1": "node scripts/run-repro-bundle-v1.mjs",
    "rerun:contract": "node scripts/run-rerun-contract.mjs",
    "validate:structure": "node scripts/validate-module-structure.mjs",
    "validate:repo-policy": "node scripts/validate-repo-policy.mjs",
    "validate:val-suite": "node scripts/validate-validation-suite.mjs --scope=core",
    "validate:val-suite:all": "node scripts/validate-validation-suite.mjs --scope=all",
    "validate:daily": "npm run lint && npm run test:sim && npm run validate:structure && npm run validate:val-suite",
    "validate:stage": "node scripts/validate-stage-gate.mjs",
    "validate:nightly": "npm run lint && npm run build && npm run test:sim && npm run validate:rigor && npm run validate:structure && npm run validate:repo-policy && npm run validate:val-suite:all"
  },
  "keywords": [
    "3d",
    "visualization",
    "spatial",
    "interactive"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satellite.js": "^6.0.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^5.1.0",
    "sass": "^1.93.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
