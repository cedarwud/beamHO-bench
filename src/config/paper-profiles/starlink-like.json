    "satellitesPerPlane": 66,
    "activeSatellitesInWindow": 7,
    "satelliteSpeedKmps": 7.6,
    "minElevationDeg": 10,
    "tle": {
      "provider": "starlink",
      "pathPattern": "tle_data/starlink/tle/starlink_*.tle",
      "selection": {
        "maxSatellites": 1584,
        "preferLatest": true
      }
    }
  },
  "beam": {
    "beamsPerSatellite": 16,
    "layout": "hex-16",
    "footprintDiameterKm": 50,
    "beamwidth3dBDeg": 4.4,
