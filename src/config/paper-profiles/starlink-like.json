{
  "profileId": "starlink-like",
  "name": "Starlink-like Real Trace Profile",
  "mode": "real-trace",
  "sourcePapers": [
    "2022_12_Seamless_Handover_in_LEO_Based_Non-Terrestrial_Networks_Service_Continuity_and_Optimization"
  ],
  "timeStepSec": 1,
  "scenario": {
    "deployment": "suburban",
    "areaKm": {
      "width": 120,
      "height": 120
    }
  },
  "constellation": {
