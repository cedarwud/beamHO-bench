      "a3TttMs": 0,
      "a4ThresholdDbm": -101,
      "homDb": 2,
      "mtsSec": 1,
      "timerAlphaOptions": [0.8, 0.85, 0.9]
    }
  },
  "kpis": [
    "throughput",
    "handover-rate",
    "hof",
    "rlf",
    "uho",
    "hopp",
    "avg-dl-sinr",
    "jain-fairness"
